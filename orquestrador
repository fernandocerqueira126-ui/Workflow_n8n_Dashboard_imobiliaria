put[\"intenção\"] === \"agendamento_confirmado\" || aiOutput[\"intenção\"] === \"reagendamento_solicitado\") {\n  dataFormatada = formatarData(aiOutput.data_agendamento);\n  horaAgendamento = formatarHora(aiOutput.hora_agendamento);\n  codigoImovel = aiOutput.codigo_imovel || null;\n  corretor = aiOutput.corretor || \"Carlos Mendes\";\n\n  if (aiOutput[\"intenção\"] === \"reagendamento_solicitado\") {\n    dataAntiga = formatarData(aiOutput.data_antiga);\n    horaAntiga = formatarHora(aiOutput.hora_antiga);\n  }\n}\n\n// 8. Retorna objeto padronizado\nreturn {\n  \"intenção\": aiOutput[\"intenção\"],\n  mensagem: aiOutput.mensagem,\n  data_agendamento: dataFormatada,\n  hora_agendamento: horaAgendamento,\n  data_antiga: dataAntiga,\n  hora_antiga: horaAntiga,\n  codigo_imovel: codigoImovel,\n  corretor: corretor\n};\n"
